keybind = global:alt+cmd+space=toggle_visibility
maximize = true

# Claude Code multi-line input
keybind = shift+enter=text:\x1b\r

# Remap Ghostty shortcuts to tmux (\x02 = Ctrl+B, tmux prefix)
keybind = cmd+d=text:\x02%
keybind = cmd+shift+d=text:\x02"
keybind = cmd+w=text:\x02x
keybind = cmd+t=text:\x02c
keybind = cmd+p=text:\x02w
keybind = cmd+left_bracket=text:\x02p
keybind = cmd+right_bracket=text:\x02n
keybind = super+[=unbind
keybind = super+]=unbind
